	"scripts": {
		"start": "concurrently --kill-others \"yarn run backend:development\" \"yarn run frontend:development\"",
		"backend:build": "node app.js",
		"backend:development": "nodemon app.js",
		"frontend:build": "webpack --config webpack.config.build.js",
		"frontend:development": "cross-env NODE_ENV=dev webpack serve --config webpack.config.development.js"
	},
